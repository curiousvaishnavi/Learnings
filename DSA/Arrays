#3.Linear Search (Whether element present or not in an array)

#include<iostream>
using namespace std;

bool linSearch(int arr[],int n,int key){
    for(int i=0;i<n;i++){
        if(arr[i]==key){
            return 1;
        }
    }return 0;
}

int main(){

    int size;
    cout<<"Enter the size of an array"<<endl;
    cin>>size;

    int num[100];

    cout<<"Enter the elements of an array"<<endl;
    
    for(int i=0;i<size;i++){
        cin>>num[i];
    }

    int elem;
    cout<<"Enter the element for search"<<endl;
    cin>>elem;

    int found=linSearch(num,size,elem);

    if(found){
        cout<<"Element is Present";
    }else{
        cout<<"Element is Absent";
    }
}

/*Output:

