#4.Reverse an array

#include<iostream>
using namespace std;

void printArray(int arr[],int n){
    cout<<"Reverse array is ";
    for(int i=0;i<n;i++){
        cout<<arr[i]<<" ";
    }
}

void rev(int arr[],int n){
    int start=0;
    int end=n-1;

    while(start<=end){
        swap(arr[start],arr[end]);
        start++;
        end--;
    }
    
}


int main(){

    int size;
    cout<<"Enter the size of an array"<<endl;
    cin>>size;

    int num[100];

    cout<<"Enter the elements of an array"<<endl;
    
    for(int i=0;i<size;i++){
        cin>>num[i];
    }

    rev(num,size);
    printArray(num,size);

}

/*Output:

Enter the size of an array
5
Enter the elements of an array
3
5
2
6
7 
Reverse array is 7 6 2 5 3*/


#5.Swap alternate element

#include<iostream>
using namespace std;

void print(int arr[],int n){
    for(int i=0;i<n;i++){
        cout<<arr[i]<<" ";
    }
}

void altSwap(int arr[],int n){
    for(int i=0;i<n;i+=2){
        
        // To check whether paired element is present in an array or not
        if(i+1 < n){
            swap(arr[i],arr[i+1]);
        }
    }
}


int main(){

    int size;
    cout<<"Enter the size of an array"<<endl;
    cin>>size;

    int num[100];

    cout<<"Enter the elements of an array"<<endl;
    
    for(int i=0;i<size;i++){
        cin>>num[i];
    }

    altSwap(num,size);
    print(num,size);

}

