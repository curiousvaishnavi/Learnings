#4.Reverse an array

#include<iostream>
using namespace std;

void printArray(int arr[],int n){
    cout<<"Reverse array is ";
    for(int i=0;i<n;i++){
        cout<<arr[i]<<" ";
    }
}

void rev(int arr[],int n){
    int start=0;
    int end=n-1;

    while(start<=end){
        swap(arr[start],arr[end]);
        start++;
        end--;
    }
    
}


int main(){

    int size;
    cout<<"Enter the size of an array"<<endl;
