#5.Number of set bits

#include<iostream>
using namespace std;

int counter(int a){
    int count=0;
    while(a!=0){
        if(a&1){
            count++;
        }
        a=a>>1;
    }
    return count;
}

int setBitCounter(int num1,int num2){
    int a=counter(num1);
    int b=counter(num2);
    int ans=a+b;
    return ans;
}

int main(){
    int a,b;
    cout<<"Enter a and b"<<endl;
    cin>>a>>b;

    cout<<"No.of set bit is "<<setBitCounter(a,b);
}

/*Output:

Enter a and b
11
7
No.of set bit is 6*/


#6.Nth fibonacci value finder

#include<iostream>
using namespace std;

int nFibonacci(int n){
    int a=0;
    int b=1;
    int sum=0;
    for(int i=3;i<=n;i++){
        sum=a+b;
        a=b;
        b=sum;
    }
    return sum;
}

int main(){
    int n;
    cout<<"Enter the value of n"<<endl;
    cin>>n;
    
    cout<<"You're nth fibonacci term's value is "<<nFibonacci(n);
    
}

