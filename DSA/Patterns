4 5 6 7

#include<iostream>
using namespace std;

int main(){
    int n;
    cout<<"Enter the no. of rows"<<endl;
    cin>>n;

    int row=1;
    while(row<=n){
        int col=1;                                                                        
        int val=row;          //Introduce a new variable val to track and print row no.   
        while(col<=row){                                                                  
            cout<<val<<" ";
            val=val+1;
            col=col+1;
        }
        cout<<endl;
        row=row+1;
    }
}

//Another way
//You can print the same pattern without introducing the val variable by using row + col - 1 directly inside the cout statement.
