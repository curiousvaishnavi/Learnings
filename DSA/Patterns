#include<iostream>
using namespace std;

int main(){

    int n;
    cout<<"Enter the no. of rows"<<endl;
    cin>>n;

    int row=1;
    while(row<=n){
        int col=1;
        char ch=('A'+n-row);        //'A'+n-row   then increment
        while(col<=row){
            cout<<ch<<" ";
            ch=ch+1;
            col=col+1;
        }
        cout<<endl;
        row=row+1;
    }
}







