#2.Number is Even or odd

#include <iostream>
using namespace std;

bool isEven(int a){
   if(a&1){
    return 0;
   }
   return 1;
}

int main(){
    int num;
    cout<<"Enter the number"<<endl;
    cin>>num;

    int ans=isEven(num);

    if(ans==true){
        cout<<"Number is Even";
    }
    else{
        cout<<"Number is odd";
    }
}

